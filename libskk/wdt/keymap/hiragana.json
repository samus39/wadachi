{
    "include": [
        "default",
        "common"
    ],
    "define": {
        "keymap": {
            "=": "set-input-mode-katakana",
            "\n": "commit-unhandled",
            "\t": "complete",
            " ": "next-candidate",
            "b": "previous-candidate",
            "Delete": "purge-candidate",
            "C-d": "purge-candidate"
        }
    }
}
